<div class="hero">
  <h1>blog<span>.pablogeorge.org</span></h1>
  <p>Notes from a software engineer learning DevOps, AI, and better ways to build things. I work on an ERP platform at Cox Automotive, run Kubernetes in my spare time, and write here when something clicks.</p>
</div>

<% if (posts.length === 0) { %>
  <div class="posts-grid">
    <div class="empty-state">
      <p>No posts yet. <% if (user) { %><a href="/posts/new">Create the first one!</a><% } else { %><a href="/login">Login</a> to create posts.<% } %></p>
    </div>
  </div>
<% } else { %>
  <div class="section-header">
    <h2 class="section-title">Recent Posts</h2>
    <a href="/posts" class="view-all">View All Posts &rarr;</a>
  </div>
  <div class="posts-grid">
    <% posts.forEach(post => { %>
      <a href="/posts/<%= post.id %>" class="post-card">
        <% if (post.featured_image) { %>
          <img src="<%= post.featured_image %>" alt="<%= post.title %>" class="post-card-img">
        <% } else { %>
          <div class="post-card-img-placeholder"></div>
        <% } %>
        <div class="post-card-body">
          <div class="post-card-date"><%= new Date(post.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></div>
          <div class="post-card-title"><%= post.title %></div>
          <% if (post.excerpt) { %>
            <div class="post-card-excerpt"><%= post.excerpt %></div>
          <% } %>
          <span class="read-more">Read More &raquo;</span>
        </div>
      </a>
    <% }) %>
  </div>
<% } %>
