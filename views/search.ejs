<div class="search-header">
  <h1>Search Results</h1>
  <p><% if (query) { %>Showing results for "<strong><%= query %></strong>"<% } else { %>Enter a search term above.<% } %></p>
</div>

<% if (results.length === 0 && query) { %>
  <div class="posts-grid">
    <div class="empty-state">
      <p>No posts found for "<strong><%= query %></strong>". Try a different search.</p>
    </div>
  </div>
<% } else { %>
  <div class="posts-grid">
    <% results.forEach(post => { %>
      <a href="/posts/<%= post.id %>" class="post-card">
        <% if (post.featured_image) { %>
          <img src="<%= post.featured_image %>" alt="<%= post.title %>" class="post-card-img">
        <% } else { %>
          <div class="post-card-img-placeholder"></div>
        <% } %>
        <div class="post-card-body">
          <div class="post-card-date"><%= new Date(post.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></div>
          <div class="post-card-title"><%= post.title %></div>
          <% if (post.excerpt) { %>
            <div class="post-card-excerpt"><%= post.excerpt %></div>
          <% } %>
          <span class="read-more">Read More &raquo;</span>
        </div>
      </a>
    <% }) %>
  </div>
<% } %>
