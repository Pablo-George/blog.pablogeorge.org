<div class="post-form-wrap">
  <div class="page-eyebrow">Edit post</div>
  <h1>Edit Post</h1>

  <form action="/posts/<%= post.id %>?_method=PUT" method="POST" hx-boost="true">
    <div>
      <label for="title">Title</label>
      <input type="text" name="title" id="title" value="<%= post.title %>" required>
    </div>
    <div>
      <label for="excerpt">Excerpt</label>
      <textarea name="excerpt" id="excerpt" rows="2"><%= post.excerpt || '' %></textarea>
    </div>
    <div>
      <label for="featured_image">Featured Image URL</label>
      <input type="url" name="featured_image" id="featured_image" value="<%= post.featured_image || '' %>" placeholder="https://...">
    </div>
    <div>
      <label for="content">Content (Markdown supported)</label>
      <div class="editor-toolbar">
        <button type="button" class="toolbar-btn" id="upload-btn" title="Upload image">
          &#128247; Upload Image
        </button>
        <span class="toolbar-hint">or paste an image from clipboard anywhere in the editor</span>
        <input type="file" id="image-input" accept="image/*" style="display:none">
      </div>
      <textarea name="content" id="content" rows="18" required><%= post.content %></textarea>
    </div>
    <div>
      <label for="status">Status</label>
      <select name="status" id="status">
        <option value="draft" <%= post.status === 'draft' ? 'selected' : '' %>>Draft</option>
        <option value="published" <%= post.status === 'published' ? 'selected' : '' %>>Published</option>
      </select>
    </div>
    <button type="submit">Update Post</button>
    <a href="/" class="button ghost" style="margin-left: 0.5rem;">Cancel</a>
  </form>

  <form action="/posts/<%= post.id %>?_method=DELETE" method="POST" style="margin-top: 3rem;"
        hx-confirm="Are you sure you want to delete this post?">
    <button type="submit" class="button danger">Delete Post</button>
  </form>
</div>

<%- include('./upload-script.ejs') %>
